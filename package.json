{
  "name": "@lamatemaga/sterling",
  "version": "0.1.0",
  "description": "A palette and React/MDX components for editorial data stories.",
  "keywords": ["data-visualization", "react", "mdx", "d3", "charts", "editorial"],
  "license": "MIT",
  "homepage": "https://www.lamatemaga.com/sterling",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LaMatemaga/sterling.git"
  },
  "bugs": {
    "url": "https://github.com/LaMatemaga/sterling/issues"
  },
  "engines": {
    "node": ">=18.18"
  },
  "sideEffects": ["./dist/styles.css", "./dist/editorial.css"],
  "files": ["dist", "assets/fonts"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./styles.css": "./dist/styles.css",
    "./editorial.css": "./dist/editorial.css",
    "./assets/fonts/*": "./assets/fonts/*"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && copyfiles -u 1 src/styles.css src/editorial.css dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build",
    "test:consumer": "node scripts/consumer-smoke.mjs"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "d3-chord": "^3.0.1",
    "d3-geo": "^3.1.1",
    "d3-hierarchy": "^3.1.2",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@types/d3-chord": "^3.0.6",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/topojson-client": "^3.1.5",
    "copyfiles": "^2.4.1",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
